# Import libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Load dataset from GitHub
url = "https://raw.githubusercontent.com/athi-raj/Rainfall-Prediction/main/daily-rainfall-at-state-level.csv"
df = pd.read_csv(url)

# Display first few records
print(df.head())

# Check shape of dataset
print("Shape:", df.shape)

# Dataset information
df.info()

# Summary statistics
print(df.describe())

# Check missing values
print(df.isnull().sum())

# Fill missing numerical values with median
for col in df.select_dtypes(include=['float64', 'int64']).columns:
    df[col] = df[col].fillna(df[col].median())

# Check duplicate rows
print("Duplicate Rows:", df.duplicated().sum())

# Remove duplicates
df.drop_duplicates(inplace=True)

# Convert date column to datetime format
df['date'] = pd.to_datetime(df['date'])

# Create month column
df['Month'] = df['date'].dt.month_name()

# Display data types
print(df.dtypes)

# Visualize missing values
plt.figure(figsize=(10,5))
sns.heatmap(df.isnull(), cbar=False)
plt.title("Missing Values")
plt.show()

# Distribution of actual rainfall
plt.figure(figsize=(10,5))
sns.histplot(df['actual'], bins=30, kde=True)
plt.title("Distribution of Actual Rainfall")
plt.xlabel("Rainfall")
plt.ylabel("Frequency")
plt.show()

# Average rainfall by state
state_avg = df.groupby('state_name')['actual'].mean()
state_avg = state_avg.sort_values(ascending=False)

plt.figure(figsize=(12,6))
state_avg.head(10).plot(kind='bar')
plt.title("Top 10 States by Average Rainfall")
plt.xlabel("State")
plt.ylabel("Average Rainfall")
plt.show()

# Monthly rainfall trend
monthly_avg = df.groupby('Month')['actual'].mean()

plt.figure(figsize=(10,5))
monthly_avg.plot(marker='o')
plt.title("Monthly Rainfall Trend")
plt.xlabel("Month")
plt.ylabel("Average Rainfall")
plt.show()

# Outlier detection
plt.figure(figsize=(8,5))
sns.boxplot(x=df['actual'])
plt.title("Outlier Detection in Rainfall Data")
plt.show()

# Correlation heatmap
plt.figure(figsize=(8,6))
sns.heatmap(
    df[['actual', 'rfs', 'normal', 'deviation']].corr(),
    annot=True,
    cmap='coolwarm'
)
plt.title("Correlation Matrix")
plt.show()

# Final dataset shape after cleaning
print("Final Shape:", df.shape)



# Statistical Summary
print("Statistical Summary")
print(df.describe())


# Average rainfall by state
state_avg = df.groupby('state_name')['actual'].mean().sort_values(ascending=False)

plt.figure(figsize=(12,6))
state_avg.head(10).plot(kind='bar')
plt.title("Top 10 States by Average Rainfall")
plt.xlabel("State")
plt.ylabel("Average Rainfall")
plt.show()




# Monthly rainfall trend
df['Month'] = df['date'].dt.month_name()

monthly_avg = df.groupby('Month')['actual'].mean()

plt.figure(figsize=(10,5))
monthly_avg.plot(marker='o')
plt.title("Monthly Average Rainfall")
plt.xlabel("Month")
plt.ylabel("Rainfall")
plt.show()



# Yearly rainfall trend
df['Year'] = df['date'].dt.year

yearly_avg = df.groupby('Year')['actual'].mean()

plt.figure(figsize=(12,5))
yearly_avg.plot()
plt.title("Yearly Average Rainfall Trend")
plt.xlabel("Year")
plt.ylabel("Rainfall")
plt.show()



# Rainfall distribution
plt.figure(figsize=(8,5))
sns.histplot(df['actual'], bins=30, kde=True)
plt.title("Rainfall Distribution")
plt.show()




# Correlation analysis
plt.figure(figsize=(8,6))
sns.heatmap(
    df[['actual','rfs','normal','deviation']].corr(),
    annot=True,
    cmap='coolwarm'
)
plt.title("Correlation Matrix")
plt.show()





# Relationship between actual and normal rainfall
plt.figure(figsize=(8,5))
sns.scatterplot(x='normal', y='actual', data=df)
plt.title("Actual vs Normal Rainfall")
plt.show()





# State-wise rainfall boxplot
plt.figure(figsize=(14,6))
top_states = df['state_name'].value_counts().head(10).index
sns.boxplot(data=df[df['state_name'].isin(top_states)],
            x='state_name', y='actual')
plt.xticks(rotation=45)
plt.title("Rainfall Distribution Across States")
plt.show()




# Key observations
print("\nKey Insights:")
print("- Rainfall varies significantly across different states.")
print("- Monsoon months receive higher rainfall.")
print("- Actual rainfall shows correlation with normal rainfall.")
print("- Some states experience extreme rainfall events.")
print("- Seasonal and yearly rainfall patterns are visible in the data.")
